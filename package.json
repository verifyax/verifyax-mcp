{
  "name": "verifyax-mcp-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for the VerifyAX SDK and MCP server.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "clean": "tsc -b --clean",
    "test": "pnpm -r test",
    "test:integration": "pnpm --filter @verifyax/sdk test:integration",
    "test:conformance": "pnpm --filter @verifyax/mcp-server test:conformance",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.0.2"
  }
}
