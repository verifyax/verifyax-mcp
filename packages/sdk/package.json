{
  "name": "@verifyax/sdk",
  "version": "0.1.0",
  "description": "Typed TypeScript client for the VerifyAX agent-evaluation REST API.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "msw": "^2.7.0"
  }
}
