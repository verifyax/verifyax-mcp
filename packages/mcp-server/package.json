{
  "name": "@verifyax/mcp-server",
  "mcpName": "io.github.verifyax/mcp-server",
  "version": "0.2.1",
  "description": "MCP server exposing the VerifyAX agent-evaluation platform as conversational tools.",
  "license": "Apache-2.0",
  "author": "Conscium",
  "homepage": "https://github.com/verifyax/verifyax-mcp/tree/main/packages/mcp-server#readme",
